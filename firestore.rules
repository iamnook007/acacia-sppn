rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    match /installations/{id} {
      function onlyAllowedFields() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status',
          'photos',
          'serialNumbers',
          'installer',
          'completedAt',
          'exported',
          'exportedAt',
          'flags'
        ]);
      }

      function statusTransitionOk() {
        let oldStatus = resource.data.status;
        let newStatus = request.resource.data.status;
        return newStatus == oldStatus
          || (oldStatus == 'pending'   && newStatus == 'uploading')
          || (oldStatus == 'uploading' && newStatus == 'completed')
          || (oldStatus == 'pending'   && newStatus == 'completed');
      }

      allow read:   if signedIn();
      allow create: if false;
      allow delete: if false;
      allow update: if signedIn()
                       && onlyAllowedFields()
                       && statusTransitionOk();
    }

    match /qc_checks/{assetId} {
      allow read: if signedIn();
      allow create, update: if signedIn()
        && request.resource.data.keys().hasAll(['assetId', 'checkedBy', 'checkedAt'])
        && request.resource.data.assetId == assetId;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
